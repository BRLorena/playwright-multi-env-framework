{
  "name": "todo-app-multi-env",
  "version": "1.0.0",
  "description": "TODO CRUD app with multi-environment UI for automation test practice",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "start:stable": "ENV_NAME=stable node dist/server.js",
    "start:release": "ENV_NAME=release node dist/server.js",
    "start:int": "ENV_NAME=int node dist/server.js",
    "dev": "ts-node app/server.ts",
    "dev:stable": "ENV_NAME=stable ts-node app/server.ts",
    "dev:release": "ENV_NAME=release ts-node app/server.ts",
    "dev:int": "ENV_NAME=int ts-node app/server.ts",
    "test": "npx playwright test",
    "test:stable": "npx playwright test --project=stable",
    "test:release": "npx playwright test --project=release",
    "test:int": "npx playwright test --project=int"
  },
  "dependencies": {
    "dotenv": "^17.4.1",
    "express": "^4.18.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.42.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.7",
    "allure-playwright": "^3.6.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
